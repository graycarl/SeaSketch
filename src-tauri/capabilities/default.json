{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "plugins": [
    "store"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "core:event:default",
    "core:menu:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    }
  ]
}